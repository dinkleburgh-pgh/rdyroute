# ReadyRoute V2 production settings.
# Update the image names to the registry paths you push to.

BACKEND_IMAGE=ghcr.io/dinkleburgh-pgh/rdyroute-backend
FRONTEND_IMAGE=ghcr.io/dinkleburgh-pgh/rdyroute-frontend
IMAGE_TAG=latest

BACKEND_PORT=8000
FRONTEND_PORT=5180
HOST_IP=192.168.1.132

# Primary DB — TrueNAS local Docker PostgreSQL
# POSTGRES_CONTAINER is the Docker container name for the DB; used by docker-entrypoint.sh
# to dynamically join the postgres container's network so the hostname resolves.
POSTGRES_CONTAINER=ix-postgres-postgres-1
DATABASE_URL=postgresql+psycopg://coxnas:coxx2026@ix-postgres-postgres-1:5432/readyroute

# Backup DB — UltraSeedbox PostgreSQL (blaze.usbx.me)
BACKUP_DATABASE_URL=postgresql+psycopg://dinkleberg:readyworkday3@blaze-direct.usbx.me:36409/dinkleberg

SECRET_KEY=rrv2_tmp_2026_05_26_c7f4e2b9a1d84c63b5e7f9a2d4c6e8f1b3a5c7d9e1f2a4b6c8d0e2f4
ALGORITHM=HS256
