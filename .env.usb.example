# ReadyRoute V2 — USB Standby Environment
# Copy to .env.usb (git-ignored) and fill in secrets before deploying.

# ── Images ───────────────────────────────────────────────────────────────────
BACKEND_IMAGE=ghcr.io/dinkleburgh-pgh/rdyroute-backend
FRONTEND_IMAGE=ghcr.io/dinkleburgh-pgh/rdyroute-frontend
IMAGE_TAG=latest

# ── Ports ────────────────────────────────────────────────────────────────────
BACKEND_PORT=8001
FRONTEND_PORT=8180

# ── App ──────────────────────────────────────────────────────────────────────
HOST_IP=blaze.usbx.me
PUBLIC_URL=https://standby.rdyroute.app
SECRET_KEY=CHANGE_ME_SAME_AS_TRUENAS_SECRET_KEY
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60
SESSION_EXPIRY_DAYS=30
CORS_ORIGINS=*
TIMEZONE=America/New_York

# ── Database ─────────────────────────────────────────────────────────────────
DB_USER=readyroute
DB_NAME=readyroute
# Must match the DB_PASSWORD set in the TrueNAS Portainer stack env
DB_PASSWORD=CHANGE_ME
# Must match DB_REPL_PASSWORD in TrueNAS Portainer stack env (no single quotes)
DB_REPL_PASSWORD=CHANGE_ME_REPL

# Primary postgres to replicate from
PRIMARY_HOST=73.117.168.91
PRIMARY_PORT=5432
REPLICATION_SLOT=usb_standby

# ── Cloudflare failover ───────────────────────────────────────────────────────
# Zone ID: Cloudflare dashboard → rdyroute.app → Overview → Zone ID (right sidebar)
CF_ZONE_ID=CHANGE_ME
# API token: Cloudflare → My Profile → API Tokens → Create Token
#   Template: Edit zone DNS  →  Zone: rdyroute.app
CF_API_TOKEN=CHANGE_ME

# This server's public IP (blaze.usbx.me resolves to this)
USB_IP=CHANGE_ME

# Target domain for automatic failover
DOMAIN=rdyroute.app
PRIMARY_IP=73.117.168.91

# Watchdog tuning
CHECK_INTERVAL=30
FAIL_THRESHOLD=3
WATCHDOG_INTERVAL_SECONDS=20
WATCHDOG_FAILURE_THRESHOLD=3

# ── Backup DB (optional on standby) ──────────────────────────────────────────
BACKUP_DATABASE_URL=
