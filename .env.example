# ReadyRoute V2 production settings.
# Copy this file to .env and update the image names to the registry paths you push to.

# Production image references.
BACKEND_IMAGE=ghcr.io/dinkleburgh-pgh/rdyroute-backend
FRONTEND_IMAGE=ghcr.io/dinkleburgh-pgh/rdyroute-frontend
IMAGE_TAG=latest

# Container ports exposed on the host.
BACKEND_PORT=8000
FRONTEND_PORT=80

# Persisted SQLite database inside the backend container.
# For PostgreSQL (e.g. local TrueNAS Docker): postgresql+psycopg://user:pass@host:5432/dbname
DATABASE_URL=sqlite:////app/.data/truckv2_prod.db

# App config injected into the backend.
SECRET_KEY=change-me-to-a-long-random-string
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60
SESSION_EXPIRY_DAYS=30
CORS_ORIGINS=*
TIMEZONE=America/New_York

# Docker watchdog tuning (auto-starts with the stack).
WATCHDOG_INTERVAL_SECONDS=20
WATCHDOG_FAILURE_THRESHOLD=3

# Portainer API — used by the in-app updater (python3 /app/docker_resolve.py portainer_redeploy)
# Generate an API token in Portainer → My account → Access tokens
PORTAINER_URL=https://your-portainer-host:9443
PORTAINER_API_KEY=[REDACTED_PORTAINER_API_KEY]
PORTAINER_STACK_ID=38
PORTAINER_ENDPOINT_ID=3

# Set this to your public URL so it prints on startup (e.g. http://192.168.1.50:80)
PUBLIC_URL=rdyroute

# Optional backup / replica database URL(s) shown in Settings → Advanced → Connections.
# Comma-separate multiple URLs. Leave empty to skip. Credentials are masked in the UI.
# Example: postgresql+psycopg://user:pass@backup-host:5432/dbname
BACKUP_DATABASE_URL=
